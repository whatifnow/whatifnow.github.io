---
import '../styles/global.css'
import StickyBookCTA from '../components/StickyBookCTA.astro';
import Analytics from '../components/Analytics.astro';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const { title, description = "AI consulting for businesses. Get AI-ready with What If Now — strategy, training, and implementation.", noindex = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/images/og-image.jpg', Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="What If Now" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts: self-hosted via @fontsource (see src/styles/global.css). -->

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- AdSense verification (activate when approved) -->
    <!-- <meta name="google-adsense-account" content="ca-pub-XXXXXXXXXXXXXXXX"> -->

    <title>{title}</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "What If Now",
      "alternateName": "WIN",
      "legalName": "What If Now Ltd",
      "description": "AI consulting for businesses — strategy, training, and implementation.",
      "disambiguatingDescription": "Dublin-based AI consultancy founded by Paul Thompson and Lar Judge — not the television programme, the Cecelia Ahern novel, or the AI artist of the same name.",
      "url": "https://www.whatifnow.ie",
      "email": "privacy@whatifnow.ie",
      "areaServed": "IE",
      "knowsAbout": ["Artificial intelligence", "Generative AI", "Retrieval-augmented generation", "EU AI Act", "GDPR", "Irish housing law"],
      "founder": [
        { "@type": "Person", "name": "Paul Thompson" },
        { "@type": "Person", "name": "Lar Judge" }
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Dublin",
        "addressCountry": "IE"
      },
      "sameAs": [
        "https://www.linkedin.com/company/whatifnow/",
        "https://github.com/whatifnow"
      ],
      "serviceType": ["AI Consulting", "AI Training", "AI Implementation", "AI Readiness Assessment"],
      "subOrganization": [
        {
          "@type": "Organization",
          "name": "righttostay.ie",
          "url": "https://www.righttostay.ie",
          "description": "Free, plain-language Irish tenant-rights tool, available in 14 languages and grounded in 25,000+ RTB Tribunal decisions."
        },
        {
          "@type": "Organization",
          "name": "Stare",
          "url": "https://stare.law",
          "description": "B2B precedent-intelligence platform for Irish legal professionals, built on the same Residential Tenancies Board decision corpus."
        }
      ]
    })} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
    <StickyBookCTA />
    <Analytics />
  </body>
</html>
