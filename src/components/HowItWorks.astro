---
const steps = [
  {
    number: "1",
    title: "Book a Scoping Call",
    description: "Tell us about your business, your goals, and where you're stuck. We'll figure out the right engagement together — no commitment, no pressure."
  },
  {
    number: "2",
    title: "Get Your Diagnostic",
    description: "We'll map your workflows, assess your AI readiness, and deliver a prioritised action plan with clear next steps and expected outcomes."
  },
  {
    number: "3",
    title: "See Results",
    description: "Whether you implement with us or independently, you'll have a concrete roadmap and the confidence to move forward."
  }
];
---

<section id="how-it-works" class="py-20 px-6 bg-off-white">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold font-serif text-center mb-4 text-navy">
      Here's How It Works. Simply.
    </h2>
    <p class="text-slate text-center text-lg mb-16 max-w-2xl mx-auto">
      Here's how working with us actually works.
    </p>

    <div class="relative">
      <!-- Connecting line (desktop) -->
      <div class="hidden md:block absolute top-8 left-[16.67%] right-[16.67%] h-0.5 bg-gradient-to-r from-teal/20 via-teal to-teal/20"></div>

      <div class="grid md:grid-cols-3 gap-8 md:gap-12">
        {steps.map((step) => (
          <div class="relative text-center">
            <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-teal text-white flex items-center justify-center text-2xl font-bold relative z-10">
              {step.number}
            </div>
            <h3 class="text-xl font-bold mb-3 text-navy">{step.title}</h3>
            <p class="text-slate leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
