---
const painPoints = [
  {
    quote: "Where do we even start with AI?",
    description: "New tools launch every week. Your team is overwhelmed by options and paralysed by choice. You need a clear starting point, not more noise."
  },
  {
    quote: "We don't have time to experiment.",
    description: "You're running a business, not a research lab. Every hour on the wrong tool is an hour lost. You need guidance that respects your time."
  },
  {
    quote: "What about compliance and risk?",
    description: "GDPR, the EU AI Act, data governance — the landscape is shifting. You need AI adoption that's compliant from day one, not an afterthought."
  }
];
---

<section class="py-20 px-6 bg-navy">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-14">
      <span class="inline-block text-teal font-ui font-bold text-xs tracking-widest uppercase mb-4">What we hear</span>
      <h2 class="text-3xl md:text-4xl font-bold text-white font-serif mb-3">Sound familiar?</h2>
      <p class="text-slate-light text-lg max-w-2xl mx-auto">
        These are the questions we hear every day. You're not alone — and there are good answers.
      </p>
    </div>

    <div class="space-y-8">
      {painPoints.map((point) => (
        <blockquote class="border-l-4 border-teal pl-6 md:pl-8">
          <p class="font-serif text-2xl md:text-3xl text-white leading-snug mb-3">&ldquo;{point.quote}&rdquo;</p>
          <p class="text-slate-light leading-relaxed">{point.description}</p>
        </blockquote>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/contact?subject=Scoping+call" class="inline-flex items-center gap-2 text-teal font-ui font-bold hover:text-white transition-colors">
        Sound like your team? Book a 20-min scoping call
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
