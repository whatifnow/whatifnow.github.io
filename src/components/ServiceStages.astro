---
const stages = [
  {
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342"/></svg>`,
    title: "Getting Started",
    description: "Learn the landscape. Understand what AI can (and can't) do for your business.",
    deliverables: ["Team workshops", "AI literacy training", "Tool landscape overview"]
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z"/></svg>`,
    title: "Readiness Assessment",
    description: "We audit your workflows, data, and team readiness for AI adoption.",
    deliverables: ["Process audit", "Data readiness report", "Prioritised opportunity map"]
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z"/></svg>`,
    title: "Workflow Design",
    description: "Design AI-enhanced workflows that fit your team and your budget.",
    deliverables: ["Workflow blueprints", "Tool selection", "Implementation roadmap"]
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z"/></svg>`,
    title: "Custom Build",
    description: "We build, test, and deploy custom AI solutions tailored to your operations.",
    deliverables: ["Custom AI tools", "Integration support", "Training & handover"]
  }
];
---

<section id="services" class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 font-serif">
      From Friction to Fixed
    </h2>
    <p class="text-slate-light text-center text-lg mb-16 max-w-2xl mx-auto">
      We meet you where you are — whether you need literacy, strategy, or full implementation.
    </p>

    <div class="relative">
      <!-- Connecting line (desktop) -->
      <div class="hidden md:block absolute top-12 left-[12.5%] right-[12.5%] h-0.5 bg-gradient-to-r from-teal/20 via-teal to-teal/20"></div>

      <!-- Connecting line (mobile) -->
      <div class="md:hidden absolute top-0 bottom-0 left-6 w-0.5 bg-gradient-to-b from-teal/20 via-teal to-teal/20"></div>

      <div class="grid md:grid-cols-4 gap-8">
        {stages.map((stage, index) => (
          <div class="relative pl-12 md:pl-0 md:text-center">
            <!-- Stage number badge (mobile: left side, desktop: centered) -->
            <div class="absolute left-0 md:relative md:left-auto w-12 h-12 mx-auto mb-4 rounded-full bg-navy-light border-2 border-teal flex items-center justify-center text-teal relative z-10">
              <div set:html={stage.icon} />
            </div>
            <div class="bg-navy-light p-6 rounded-2xl mt-2 md:mt-0">
              <h3 class="text-lg font-bold mb-2 text-white">{stage.title}</h3>
              <p class="text-slate-light text-sm mb-4 leading-relaxed">{stage.description}</p>
              <ul class="space-y-1">
                {stage.deliverables.map((d) => (
                  <li class="text-slate text-sm flex items-start gap-2">
                    <span class="text-teal mt-1 flex-shrink-0">•</span>
                    {d}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
