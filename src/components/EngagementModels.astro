---
const formats = [
  {
    initial: "B",
    duration: "90 min — half day",
    title: "Briefing",
    description: "A plain-English session for a leadership team or board. What AI can do for an organisation your size — and what it can't.",
    price: "from €750",
    unit: "/ session",
    cta: "Request a briefing",
    ctaLink: "/contact?subject=Briefing",
    featured: false
  },
  {
    initial: "W",
    duration: "1–2 days · on-site or remote",
    title: "Workshop",
    description: "Theory in the morning, hands-on labs in the afternoon. Your team leaves having actually built something — a custom GPT, a triage flow, an inventory.",
    price: "from €2,500",
    unit: "/ day",
    cta: "Book a workshop",
    ctaLink: "/contact?subject=Workshop",
    featured: true,
    pop: "MOST BOOKED"
  },
  {
    initial: "P",
    duration: "Fractional · sprint or retainer",
    title: "Pairing",
    description: "One or two days a week beside one of yours, on the task they're stuck on — strategy, governance, ops. Sprint-bounded for a defined push, or rolling as ongoing fractional AI officer cover.",
    price: "from €4,000",
    unit: "/ sprint",
    cta: "Explore pairing",
    ctaLink: "/contact?subject=Pairing",
    featured: false
  },
  {
    initial: "B",
    duration: "4–10 weeks · fixed fee",
    title: "Build",
    description: "We design, build, and ship a working AI tool tailored to your operation. Fixed scope, fixed fee. We document, train, and step out. Commercial fit — bespoke or product-based — agreed in scoping.",
    price: "from €12,000",
    unit: "/ build",
    cta: "Scope a build",
    ctaLink: "/contact?subject=Build",
    featured: false
  }
];
---

<section id="services" class="py-20 px-6 bg-off-white">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 text-navy font-serif">
      Pick the engagement that fits.
    </h2>
    <p class="text-slate text-center text-lg mb-3 max-w-2xl mx-auto">
      Four formats. The price floors are real — actual scope agreed on the call.
    </p>
    <p class="text-slate text-center text-sm mb-14 max-w-3xl mx-auto opacity-80">
      Inside any engagement we typically deliver some combination of AI strategy, custom automation builds, fractional AI officer cover, and team training.
    </p>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 items-stretch">
      {formats.map((fmt) => (
        <div class={`relative p-6 rounded-2xl flex flex-col gap-2 ${
          fmt.featured
            ? 'bg-navy text-white border-2 border-teal'
            : 'bg-white border border-slate/15'
        }`}>
          {fmt.featured && fmt.pop && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-teal text-navy font-ui font-bold text-[11px] tracking-widest uppercase px-3 py-1 rounded-full whitespace-nowrap">
              {fmt.pop}
            </span>
          )}
          <div class={`w-9 h-9 rounded-lg flex items-center justify-center font-serif text-lg ${
            fmt.featured ? 'bg-teal text-navy' : 'bg-teal/10 text-teal-dark'
          }`}>
            {fmt.initial}
          </div>
          <div class={`text-xs font-ui tracking-wider uppercase mt-1 font-bold ${
            fmt.featured ? 'text-teal' : 'text-teal-dark'
          }`}>
            {fmt.duration}
          </div>
          <h3 class={`text-xl font-bold font-serif ${
            fmt.featured ? 'text-white' : 'text-navy'
          }`}>
            {fmt.title}
          </h3>
          <p class={`text-sm leading-relaxed ${
            fmt.featured ? 'text-slate-light' : 'text-slate'
          }`}>
            {fmt.description}
          </p>
          <div class={`font-serif text-2xl mt-auto pt-4 border-t border-dashed ${
            fmt.featured ? 'text-white border-white/15' : 'text-navy border-slate/15'
          }`}>
            {fmt.price}<span class={`font-ui text-sm font-medium ml-1 ${
              fmt.featured ? 'text-slate-light' : 'text-slate'
            }`}>{fmt.unit}</span>
          </div>
          <a
            href={fmt.ctaLink}
            class={`block text-center py-2.5 px-4 rounded-full font-ui font-bold text-sm transition-colors mt-2 ${
              fmt.featured
                ? 'bg-teal text-navy hover:bg-teal-dark hover:text-white'
                : 'bg-navy text-white hover:bg-navy-light'
            }`}
          >
            {fmt.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
