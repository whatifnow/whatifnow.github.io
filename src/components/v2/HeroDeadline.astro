        <div class="flex flex-wrap gap-6 font-mono text-xs text-slate-light">
          <span>· EU-HOSTED</span>
          <span>· FIXED FEE</span>
          <span>· AMNESTY BEFORE AUDIT</span>
        </div>
      </div>

      <div>
        <div class="bg-navy-light rounded-2xl p-6 border border-white/10 font-mono text-sm">
          <p class="text-slate-light mb-4">Sample AI inventory · 14 staff</p>
          <div class="border-t border-white/10 pt-4 space-y-3">
            <div class="flex items-center justify-between gap-4">
              <span class="text-white">▸ ChatGPT Plus × 6 users</span>
              <span class="text-slate-light text-xs whitespace-nowrap">· risk: limited</span>
            </div>
            <div class="flex items-center justify-between gap-4">
              <span class="text-white">▸ Copilot (M365) × 11 users</span>
              <span class="text-slate-light text-xs whitespace-nowrap">· risk: limited</span>
            </div>
            <div class="flex items-center justify-between gap-4">
              <span class="text-amber">▸ Zapier + Claude (triage)</span>
              <span class="text-amber text-xs whitespace-nowrap">· risk: HIGH ⚠</span>
            </div>
            <div class="flex items-center justify-between gap-4">
              <span class="text-amber">▸ Custom GPT (summaries)</span>
              <span class="text-amber text-xs whitespace-nowrap">· risk: HIGH ⚠</span>
            </div>
            <div class="flex items-center justify-between gap-4">
              <span class="text-white">▸ Otter.ai meeting notes</span>
              <span class="text-slate-light text-xs whitespace-nowrap">· risk: limited</span>
            </div>
          </div>
          <div class="border-t border-white/10 mt-4 pt-4">
            <p class="text-teal text-xs">2 high-risk systems need Article 9 review by Aug.</p>
          </div>
        </div>
