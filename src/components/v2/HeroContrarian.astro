<section class="bg-off-white min-h-screen flex items-center pt-20 pb-16 px-6">
  <div class="max-w-7xl mx-auto w-full grid lg:grid-cols-2 gap-16 items-center">

    <div class="flex flex-col gap-6">
      <p class="font-ui uppercase tracking-wide text-sm text-teal-dark">Illumination before enforcement</p>

      <h1 class="font-serif text-5xl lg:text-6xl text-navy leading-tight">
        We audit the AI your team<br />
        is already using.
      </h1>

      <p class="text-slate text-xl max-w-lg leading-relaxed">
        The quiet ChatGPT tabs. The Copilot transcripts. The rogue Zapier jobs. We map them to the EU AI Act, turn them into compliant, owned infrastructure — and hand you the keys. Amnesty, not audit.
      </p>

      <div class="flex flex-col items-start gap-2">
        <a
          href="/contact"
          class="bg-navy text-white rounded-full px-8 py-4 text-lg font-ui font-medium hover:bg-navy-light transition-colors"
        >
          Start your AI amnesty →
        </a>
        <span class="text-teal-dark text-sm font-ui">20 min · free · no sales call</span>
      </div>

      <div class="flex gap-6 mt-8 font-mono text-xs text-slate">
        <span>· EU AI ACT MAPPING</span>
        <span>· FIXED FEE</span>
        <span>· AMNESTY FIRST</span>
      </div>
    </div>

    <div class="bg-navy rounded-2xl p-6 font-mono text-sm">
      <p class="text-teal mb-1">$ ai-inventory --org "Sample Co." --staff 14</p>
      <p class="text-slate-light">─────────────────────────────────────────────</p>
      <div class="flex items-center gap-2 my-3">
        <span class="text-slate-light">Scanning for AI tool usage...</span>
        <span class="bg-green-400 rounded-full w-2 h-2 animate-pulse inline-block"></span>
      </div>

      <div class="flex flex-col gap-2 my-3">
        <div class="flex justify-between gap-4">
          <span class="text-slate-light">  ChatGPT Plus         × 6 users</span>
          <span class="text-slate-light">limited risk</span>
        </div>
        <div class="flex justify-between gap-4">
          <span class="text-slate-light">  Copilot (M365)       × 11 users</span>
          <span class="text-slate-light">limited risk</span>
        </div>
        <div class="flex justify-between gap-4">
          <span class="text-slate-light">  Zapier + Claude      in use</span>
          <span class="text-amber font-bold">⚠ HIGH RISK</span>
        </div>
        <div class="flex justify-between gap-4">
          <span class="text-slate-light">  Custom GPT           in use</span>
          <span class="text-amber font-bold">⚠ HIGH RISK</span>
        </div>
        <div class="flex justify-between gap-4">
          <span class="text-slate-light">  Otter.ai             × 3 users</span>
          <span class="text-slate-light">limited risk</span>
        </div>
      </div>

      <p class="text-slate-light">─────────────────────────────────────────────</p>

      <div class="flex flex-col gap-1 mt-3">
        <p class="text-teal">RESULT: 2 systems require Art. 9 review</p>
        <p class="text-teal">DEADLINE: August 2026 enforcement</p>
        <div class="flex items-center gap-2 text-teal">
          <span>ACTION: Schedule amnesty review ──────────►</span>
          <a
            href="/contact"
            class="bg-teal text-navy rounded px-2 py-0.5 text-xs font-ui font-medium hover:bg-teal-dark hover:text-white transition-colors"
          >
            Book now
          </a>
        </div>
      </div>
    </div>

  </div>
</section>
