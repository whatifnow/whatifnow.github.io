---
const testimonials = [
  {
    quote: "What If Now cut through the noise and showed us exactly where to focus. We automated our onboarding in two weeks.",
    author: "Sarah M.",
    role: "Founder",
    company: "TechStart"
  },
  {
    quote: "I was drowning in AI options. One session and I had a clear plan. Worth every cent.",
    author: "David O.",
    role: "Operations Director",
    company: "GrowthCo"
  },
  {
    quote: "Finally, someone who speaks human, not tech. They made AI feel accessible and practical for our small team.",
    author: "Aoife K.",
    role: "Business Owner",
    company: "Local Retail"
  }
];
---

<section class="py-20 px-6 bg-navy-light">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">
      What Clients Say
    </h2>
    <p class="text-slate-light text-center text-lg mb-12 max-w-2xl mx-auto">
      Real feedback from real businesses.
    </p>

    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((testimonial) => (
        <div class="bg-navy p-8 rounded-2xl">
          <!-- Quote icon -->
          <svg class="w-8 h-8 text-teal/30 mb-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>

          <p class="text-white text-lg mb-6 leading-relaxed">
            "{testimonial.quote}"
          </p>

          <div>
            <p class="font-semibold text-white">{testimonial.author}</p>
            <p class="text-slate-light text-sm">
              {testimonial.role}, {testimonial.company}
            </p>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-slate text-sm mt-8 italic">
      * Placeholder testimonials — will be replaced with real client feedback
    </p>
  </div>
</section>
