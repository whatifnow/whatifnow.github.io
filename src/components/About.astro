---
const differentiators = [
  { label: "SMEs", detail: "Our Focus" },
  { label: "Practical AI", detail: "Our Approach" }
];
---

<section id="about" class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Built for Business</h2>

      <div class="space-y-4 text-lg text-slate-light leading-relaxed">
        <p>
          What If Now was founded on a simple idea: businesses deserve AI guidance that's <strong class="text-white">practical, affordable, and honest</strong>.
        </p>
        <p>
          Our team brings decades of experience in operations, customer experience, and business transformation — combined with engineering expertise that builds the custom AI solutions powering real results.
        </p>
        <p>
          We're not here to sell you tools you don't need or strategies that don't fit. We meet you where you are, understand how your business actually works, and help you move forward with <strong class="text-white">clarity and confidence</strong>.
        </p>
      </div>
    </div>

    <!-- Differentiator tags -->
    <div class="flex flex-wrap justify-center gap-4">
      {differentiators.map((diff) => (
        <div class="bg-navy-light px-6 py-3 rounded-full">
          <span class="font-semibold text-teal">{diff.label}</span>
          <span class="text-slate-light"> · {diff.detail}</span>
        </div>
      ))}
    </div>
  </div>
</section>
