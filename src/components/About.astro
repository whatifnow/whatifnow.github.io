---
const founders = [
  {
    name: "Paul Thompson",
    title: "Co-Founder · Business Lead",
    photo: "/images/team/paul-thompson.jpg",
    bio: [
      {
        h: "Operational efficiency at scale",
        p: "20+ years leading operations and customer experience at Google, LinkedIn and Sage. CCMA board member, recognised by the CCMA and European Call Centre Awards for team transformation."
      },
      {
        h: "Champion for SME growth",
        p: "Building practical tools that eliminate administrative drag for SMEs and charities — without sacrificing compliance."
      }
    ]
  },
  {
    name: "Lar Judge",
    title: "Co-Founder · Technical Architect",
    photo: "/images/team/lar-judge.jpg",
    bio: [
      {
        h: "Engineering manager at Canva, ex-banking GenAI lead",
        p: "Leads AI development and the roll-out of agentic AI tooling to staff globally. Previously navigated strict regulatory frameworks and enterprise partnerships with Anthropic and Google at one of Australia's largest banks."
      },
      {
        h: "Bridge between tech and strategy",
        p: "15 years building and scaling digital products. Brings enterprise-grade rigour to the practical automation challenges organisations face every day, without the enterprise overhead."
      }
    ]
  }
];
---

<section id="about" class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="max-w-3xl mx-auto text-center mb-14">
      <span class="inline-block text-teal font-ui font-bold text-xs tracking-widest uppercase mb-4">Who we are</span>
      <h2 class="text-3xl md:text-4xl font-bold font-serif mb-6 text-white">Two co-founders. Decades of operations and engineering.</h2>
      <p class="text-lg text-slate-light leading-relaxed">
        We're <strong class="text-white">practical</strong>, <strong class="text-white">honest</strong>, and <strong class="text-white">capable</strong> — we build things that work, tell you what they cost, and don't sell you AI you don't need.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-10 lg:gap-16">
      {founders.map((f) => (
        <div class="flex flex-col">
          <div class="flex flex-col items-center md:items-start">
            <div class="w-32 h-32 md:w-36 md:h-36 rounded-full overflow-hidden mb-5 border-2 border-teal/30">
              <img src={f.photo} alt={`Portrait of ${f.name}`} width="288" height="288" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <h3 class="text-2xl font-bold font-serif text-amber">{f.name}</h3>
            <p class="text-white font-ui font-bold text-sm mt-1">{f.title}</p>
          </div>
          <ul class="space-y-4 mt-6">
            {f.bio.map((item) => (
              <li class="text-slate-light text-sm leading-relaxed flex gap-3">
                <span class="text-teal flex-shrink-0 mt-0.5" aria-hidden="true">→</span>
                <span><strong class="text-white">{item.h}:</strong> {item.p}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="text-center mt-14">
      <a href="/contact?subject=Scoping+call" class="inline-flex items-center gap-2 text-teal font-ui font-bold hover:text-white transition-colors">
        Want to talk to Paul or Lar directly? Book a 20-min scoping call
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
