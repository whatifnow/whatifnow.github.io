<section id="contact" class="py-24 px-6 bg-off-white">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-navy mb-6 font-serif">
      Let's Have a Conversation
    </h2>
    <p class="text-slate text-lg md:text-xl mb-10 max-w-xl mx-auto leading-relaxed">
      No pitch, no pressure — just an honest chat about where AI could help your team.
    </p>

    <a
      href="/contact"
      class="inline-block bg-amber text-charcoal font-ui px-10 py-5 rounded-full font-bold text-lg hover:bg-amber-dark transition-colors"
    >
      Let's Talk
    </a>

    <p class="text-slate text-sm mt-8">
      Usually respond within 24 hours
    </p>

    <div class="mt-10 pt-10 border-t border-slate/20">
      <p class="text-slate text-sm mb-4">Not ready to talk yet?</p>
      <a
        href="/ai-readiness"
        class="inline-flex items-center gap-2 bg-navy text-white font-ui px-8 py-4 rounded-full font-semibold text-base hover:bg-navy-light transition-colors"
      >
        Take the Free AI Readiness Assessment
        <span>→</span>
      </a>
      <p class="text-slate/60 text-xs mt-3">18 questions · 3 minutes · instant results</p>
    </div>
  </div>
</section>
