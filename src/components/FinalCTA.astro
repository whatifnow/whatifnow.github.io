<section id="contact" class="py-24 px-6 bg-navy">
  <div class="max-w-2xl mx-auto text-center">
    <span class="inline-block text-teal font-ui font-bold text-xs tracking-widest uppercase mb-5">One human, one inbox</span>
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6 font-serif leading-tight">
      Email Paul. He reads everything in this inbox.
