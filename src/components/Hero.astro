---
const quizQuestion = "In the last 30 days, how many of your team have used AI for client-facing work?";
const quizOptions = [
  { label: "None that I'm aware of",            selected: false },
  { label: "A few people, ad-hoc",              selected: true  },
  { label: "Most of the team, regularly",       selected: false },
  { label: "It's part of our standard process", selected: false }
];
---

<section class="min-h-screen flex items-center pt-20 pb-16 px-6">
  <div class="max-w-6xl mx-auto w-full">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Copy column -->
      <div class="space-y-8">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-white font-serif">
          Practical AI for teams figuring out <span class="text-teal whitespace-nowrap">where it fits</span>.
        </h1>

        <p class="text-xl md:text-2xl text-slate-light leading-relaxed">
          We're an AI consultancy. We find the manual, repetitive work eating your team's time, and build tools to handle it.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/ai-readiness"
            class="bg-teal text-navy font-ui px-8 py-4 rounded-full font-bold text-lg hover:bg-teal-dark hover:text-white transition-colors text-center"
          >
            Take the 3-minute audit
          </a>
          <a
            href="/contact?subject=Scoping+call"
            class="border-2 border-slate-light text-white font-ui px-8 py-4 rounded-full font-bold text-lg hover:bg-navy-light transition-colors text-center"
          >
            or book a 20-min call
          </a>
        </div>
      </div>

      <!-- Quiz preview card -->
      <div class="hidden lg:block">
        <div class="bg-white rounded-2xl p-6 shadow-2xl border border-slate/10 max-w-md ml-auto">
          <div class="flex justify-between items-baseline mb-5">
            <span class="font-ui font-bold text-xs tracking-widest uppercase text-teal-dark">Readiness Assessment</span>
            <span class="font-mono text-[11px] text-slate">Q 3 / 18</span>
          </div>
          <div class="h-1.5 bg-off-white rounded-full overflow-hidden mb-5">
            <div class="h-full bg-teal" style="width:18%"></div>
          </div>
          <h3 class="font-serif text-xl text-navy leading-snug mb-4">{quizQuestion}</h3>
          {quizOptions.map((opt) => (
            <div class={`flex items-center gap-3 px-3.5 py-2.5 rounded-lg border-[1.5px] mb-2 text-sm ${opt.selected ? 'border-teal bg-teal/10 text-navy' : 'border-slate/15 text-navy'}`}>
              <span class={`w-3.5 h-3.5 rounded-full border-2 flex-shrink-0 ${opt.selected ? 'border-teal bg-teal ring-2 ring-white ring-inset' : 'border-slate-light'}`}></span>
              {opt.label}
            </div>
          ))}
          <div class="mt-3 pt-3 border-t border-dashed border-slate/15 font-mono text-[11px] text-slate text-center tracking-wider">
            3 MIN · INSTANT RESULT · SECTOR BENCHMARK
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
