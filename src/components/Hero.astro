---
---

<section class="min-h-screen flex items-center pt-20 pb-16 px-6">
  <div class="max-w-6xl mx-auto w-full">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-8">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight text-white font-serif">
          Your team gets
          <span class="text-teal">their week back</span>.
        </h1>

        <p class="text-xl md:text-2xl text-slate-light leading-relaxed">
          We don't sell AI. We sell capacity. We find the tasks eating your team's time and build the tools to handle them — so your people can get back to the work only they can do. Not to cut costs. To grow.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/contact"
            class="bg-amber text-charcoal font-ui px-8 py-4 rounded-full font-semibold text-lg hover:bg-amber-dark transition-colors text-center"
          >
            Let's Talk
          </a>
          <a
            href="#how-it-works"
            class="border-2 border-slate-light text-white font-ui px-8 py-4 rounded-full font-semibold text-lg hover:bg-navy-light transition-colors text-center"
          >
            See How It Works
          </a>
        </div>
      </div>

      <div class="relative hidden lg:block">
        <!-- Abstract geometric SVG visual -->
        <svg viewBox="0 0 400 400" class="w-full h-auto" xmlns="http://www.w3.org/2000/svg">
          <!-- Grid dots pattern -->
          <defs>
            <pattern id="dots" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
              <circle cx="20" cy="20" r="2" fill="#64748B" opacity="0.3"/>
            </pattern>
          </defs>
          <rect width="400" height="400" fill="url(#dots)" rx="24"/>

          <!-- Abstract circles suggesting connectivity/transformation -->
          <circle cx="200" cy="200" r="120" fill="none" stroke="#3B5680" stroke-width="2"/>
          <circle cx="200" cy="200" r="80" fill="none" stroke="#2EC4B6" stroke-width="2" opacity="0.6"/>
          <circle cx="200" cy="200" r="40" fill="#2EC4B6" opacity="0.15"/>

          <!-- Accent nodes -->
          <circle cx="200" cy="80" r="8" fill="#2EC4B6"/>
          <circle cx="304" cy="140" r="6" fill="#2EC4B6" opacity="0.7"/>
          <circle cx="304" cy="260" r="6" fill="#2EC4B6" opacity="0.7"/>
          <circle cx="200" cy="320" r="8" fill="#2EC4B6"/>
          <circle cx="96" cy="260" r="6" fill="#2EC4B6" opacity="0.7"/>
          <circle cx="96" cy="140" r="6" fill="#2EC4B6" opacity="0.7"/>

          <!-- Connecting lines -->
          <line x1="200" y1="80" x2="304" y2="140" stroke="#2EC4B6" stroke-width="1" opacity="0.3"/>
          <line x1="304" y1="140" x2="304" y2="260" stroke="#2EC4B6" stroke-width="1" opacity="0.3"/>
          <line x1="304" y1="260" x2="200" y2="320" stroke="#2EC4B6" stroke-width="1" opacity="0.3"/>
          <line x1="200" y1="320" x2="96" y2="260" stroke="#2EC4B6" stroke-width="1" opacity="0.3"/>
          <line x1="96" y1="260" x2="96" y2="140" stroke="#2EC4B6" stroke-width="1" opacity="0.3"/>
          <line x1="96" y1="140" x2="200" y2="80" stroke="#2EC4B6" stroke-width="1" opacity="0.3"/>

          <!-- Center glow -->
          <circle cx="200" cy="200" r="12" fill="#2EC4B6" opacity="0.9"/>
        </svg>

        <!-- Decorative blur elements -->
        <div class="absolute -top-4 -right-4 w-24 h-24 bg-teal/10 rounded-full blur-2xl"></div>
        <div class="absolute -bottom-8 -left-8 w-32 h-32 bg-teal/5 rounded-full blur-3xl"></div>
      </div>
    </div>
  </div>
</section>
