---
const currentYear = new Date().getFullYear();
---

<footer class="py-8 px-6 bg-navy border-t border-navy-light">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <p class="text-slate text-sm">
      &copy; {currentYear} What If Now
    </p>

    <div class="flex items-center gap-6">
      <!-- Substack -->
      <a
        href="https://whatifnow.substack.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-slate hover:text-white transition-colors"
        aria-label="Substack"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/>
        </svg>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/company/whatifnow/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-slate hover:text-white transition-colors"
        aria-label="LinkedIn"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
        </svg>
      </a>

      <!-- Email -->
      <a
        href="mailto:hello@whatifnow.ie"
        class="text-slate hover:text-white transition-colors"
        aria-label="Email"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </a>
    </div>
  </div>
</footer>
