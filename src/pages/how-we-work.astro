---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const steps = [
  {
    number: "01",
    when: "20 min · free",
    title: "Scoping call",
    description: "A real conversation, camera on. We listen, you talk. By the end you'll know whether we're the right fit. No slides, no sales sequence.",
    upcoming: false
  },
  {
    number: "02",
    when: "1 week · fixed fee",
    title: "Diagnostic",
    description: "We map what your team already uses, what's working, what's leaking time. You get a written summary in plain English and a recommendation. Yours to keep either way.",
    upcoming: false
  },
  {
    number: "03",
    when: "Your pick",
    title: "Engagement",
    description: "Briefing, workshop, pairing, or build — whichever fits. Fixed fee agreed before kickoff. Commercial fit confirmed in scoping.",
    upcoming: false
  },
  {
    number: "04",
    when: "Weekly",
    title: "Rhythm",
    description: "Friday status note, plain language, what shipped, what didn't, what's next. You can pause or stop at any agreed milestone — no exit penalty.",
    upcoming: false
  },
  {
    number: "05",
    when: "Week N + 60 days",
    title: "Handover",
    description: "Documentation, training, and a 60-day support window. Then we step out. Someone in your seat can run what we built.",
    upcoming: true
  }
];

const formats = [
  { initial: "B", title: "Briefing",  description: "A plain-English session for a leadership team or board. What AI can do for an organisation your size.", when: "90 min — half day", price: "from €750",    unit: "/ session", featured: false },
  { initial: "W", title: "Workshop",  description: "Theory in the morning, labs in the afternoon. Your team leaves having actually built something.",       when: "1–2 days · most booked", price: "from €2,500", unit: "/ day",   featured: true  },
  { initial: "P", title: "Pairing",   description: "Fractional. One or two days a week, beside one of yours, working the task they're stuck on.",          when: "2 weeks – 3 months",    price: "from €4,000", unit: "/ sprint", featured: false },
  { initial: "B", title: "Build",     description: "Working AI tool, fixed scope, fixed fee. Commercial fit — bespoke or product-based — agreed in scoping.", when: "4–10 weeks",         price: "from €12,000",unit: "/ build",  featured: false }
];

const doList = [
  "Small organisations — 5 to 250 staff. Charities, SMEs, state-funded bodies.",
  "Practical AI you can run after we leave. Inventory, workflows, tools your team owns.",
  "Plain English the board can read. Diagnostics, recommendations, status notes.",
  "Fixed-fee engagements. Day-rate creep isn't our model."
];

const dontList = [
  "Enterprise transformation programmes. If the budget has six zeros, you want a different consultancy.",
  "Model training from scratch. We integrate frontier models; we don't fine-tune or pre-train.",
  "Long-term staff augmentation. Pairing is finite. Then you run it.",
  "Selling tools we don't believe in. No partnership kick-backs."
];
---

<Layout
  title="How we work | What If Now"
  description="Five steps. Plain English. Fixed fee from kickoff. No surprise invoices, no day-rate creep."
>
  <Navigation />
  <main>
    <!-- Hero strip -->
    <section class="bg-off-white pt-32 pb-16 px-6">
      <div class="max-w-5xl mx-auto">
        <span class="inline-block text-teal-dark font-ui font-bold text-xs tracking-widest uppercase mb-4">How we work</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-navy font-serif leading-tight mb-4">
          Five steps.<br />Plain English from the first call.
        </h1>
        <p class="text-slate text-lg md:text-xl max-w-2xl leading-relaxed">
          No surprise invoices, no day-rate creep, no consultant-speak. Here's exactly what happens between "I'm interested" and "we're done."
        </p>
      </div>
    </section>

    <!-- 5-step timeline -->
    <section class="bg-white py-16 px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold font-serif text-navy mb-2">The shape of an engagement</h2>
        <p class="text-slate text-base mb-10 max-w-2xl">
          Most engagements run on roughly this rhythm. We adapt the middle — Steps 03 and 04 — to whichever delivery format fits.
        </p>
        <div class="grid md:grid-cols-5 gap-8 md:gap-4">
          {steps.map((step) => (
            <div>
              <div class={`w-12 h-12 rounded-full border-2 bg-white flex items-center justify-center font-serif text-lg mb-4 ${step.upcoming ? 'border-slate-light text-slate' : 'border-teal text-teal-dark'}`}>
                {step.number}
              </div>
              <div class={`text-xs font-ui tracking-widest uppercase font-bold mb-2 ${step.upcoming ? 'text-slate' : 'text-teal-dark'}`}>
                {step.when}
              </div>
              <h3 class="text-lg font-bold font-serif text-navy mb-2">{step.title}</h3>
              <p class="text-slate text-sm leading-relaxed">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 4 delivery formats -->
    <section class="bg-off-white py-16 px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold font-serif text-navy mb-2">The four delivery formats</h2>
        <p class="text-slate text-base mb-8 max-w-2xl">
          Step 03 above takes the shape of one of these. People usually know which one they need by the end of the scoping call.
        </p>
        <div class="grid md:grid-cols-4 gap-4">
          {formats.map((fmt) => (
            <div class={`p-6 rounded-2xl flex flex-col gap-2 ${fmt.featured ? 'bg-navy border-2 border-teal' : 'bg-white border border-slate/15'}`}>
              <div class={`w-9 h-9 rounded-lg flex items-center justify-center font-serif text-lg ${fmt.featured ? 'bg-teal text-navy' : 'bg-teal/10 text-teal-dark'}`}>
                {fmt.initial}
              </div>
              <h4 class={`text-lg font-bold font-serif mt-1 ${fmt.featured ? 'text-white' : 'text-navy'}`}>
                {fmt.title}
              </h4>
              <p class={`text-sm leading-relaxed ${fmt.featured ? 'text-slate-light' : 'text-slate'}`}>
                {fmt.description}
              </p>
              <div class={`text-xs font-ui tracking-wider uppercase mt-2 ${fmt.featured ? 'text-teal' : 'text-teal-dark'}`}>
                {fmt.when}
              </div>
              <div class={`font-serif text-xl mt-auto pt-3 border-t border-dashed ${fmt.featured ? 'text-white border-white/20' : 'text-navy border-slate/15'}`}>
                {fmt.price}<span class={`font-ui text-xs font-medium ml-1 ${fmt.featured ? 'text-slate-light' : 'text-slate'}`}>{fmt.unit}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Candour band -->
    <section class="bg-white py-16 px-6">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold font-serif text-navy mb-3">What we do</h2>
          <div class="text-xs font-ui tracking-widest uppercase text-teal-dark font-bold mb-3">Where we're useful</div>
          <ul class="space-y-2">
            {doList.map((line) => (
              <li class="flex gap-3 text-slate text-base leading-relaxed">
                <span class="text-teal font-bold flex-shrink-0">+</span>
                <span set:html={line} />
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h2 class="text-2xl md:text-3xl font-bold font-serif text-navy mb-3">What we don't</h2>
          <div class="text-xs font-ui tracking-widest uppercase text-teal-dark font-bold mb-3">Where someone else is the right call</div>
          <ul class="space-y-2">
            {dontList.map((line) => (
              <li class="flex gap-3 text-slate text-base leading-relaxed">
                <span class="text-slate font-bold flex-shrink-0 opacity-60">−</span>
                <span set:html={line} />
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- CTA strip -->
    <section class="bg-navy text-white py-20 px-6 text-center">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold font-serif mb-4">Right then. Where are you stuck?</h2>
        <p class="text-slate-light text-lg mb-8">
          Tell us briefly and we'll set up a 20-minute call. No prep needed.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/contact?subject=Scoping+call" class="bg-teal text-navy font-ui font-bold px-7 py-3 rounded-full hover:bg-teal-dark hover:text-white transition">
            Book a 20-min scoping call
          </a>
          <a href="/ai-readiness" class="border border-white/30 text-white font-ui font-bold px-7 py-3 rounded-full hover:bg-white/10 transition">
            Or take the 3-min assessment
          </a>
        </div>
        <p class="text-slate-light text-xs font-mono tracking-widest mt-6">
          USUALLY REPLY WITHIN 24 HOURS · NO SALES SEQUENCE
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
