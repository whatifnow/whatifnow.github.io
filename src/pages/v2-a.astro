---
import Layout from '../layouts/Layout.astro';
import NavigationV2 from '../components/v2/NavigationV2.astro';
import HeroDeadline from '../components/v2/HeroDeadline.astro';
import DemosStrip from '../components/v2/DemosStrip.astro';
import HowWeWork from '../components/v2/HowWeWork.astro';
import EngagementModelsV2 from '../components/v2/EngagementModelsV2.astro';
import AboutV2 from '../components/v2/AboutV2.astro';
import FinalCTAV2 from '../components/v2/FinalCTAV2.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="What If Now | EU AI Act Readiness for Irish SMEs"
  description="Fixed-fee AI Act readiness for small businesses and charities. EU-hosted. Free 18-question assessment."
  noindex={true}
>
  <NavigationV2 />
  <main>
    <HeroDeadline />
    <DemosStrip />
    <HowWeWork />
    <EngagementModelsV2 />
    <AboutV2 />
    <FinalCTAV2 />
  </main>
  <Footer />
</Layout>

<style is:global>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  section { animation: fadeInUp 0.6s ease-out; }
  @media (prefers-reduced-motion: reduce) {
    section { animation: none; }
  }
</style>
