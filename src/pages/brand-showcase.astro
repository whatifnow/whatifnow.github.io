      <tr><td><strong>Emotional Resonance</strong> (10%)</td><td><strong style="color:#2EC4B6;">7/10</strong></td><td style="background:#F5F0FF;"><strong style="color:#F72585;">8/10</strong></td><td style="background:#E4EDE8;"><strong style="color:#2D6A4F;">9/10</strong></td></tr>
      <tr><td><strong>Technical Cred</strong> (10%)</td><td style="background:#F0F7FF;"><strong style="color:#2EC4B6;">8/10</strong></td><td style="background:#F5F0FF;"><strong style="color:#4CC9F0;">9/10</strong></td><td><strong style="color:#2D6A4F;">6/10</strong></td></tr>
      <tr style="font-weight: 700; background: #F8FAFB;">
        <td><strong>Weighted Total</strong></td>
        <td style="font-size: 20px; color: #0F2137;">7.95</td>
