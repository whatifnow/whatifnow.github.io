---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us | What If Now">
  <Navigation />
  <main id="main-content" class="bg-off-white pt-32 pb-24 px-6">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-navy mb-4 font-serif">Let's Talk</h1>
      <p class="text-slate text-lg mb-10 leading-relaxed">
        Tell us a little about what you're working on and we'll get back to you within 24 hours.
      </p>

      <form action="https://formspree.io/f/mlgojgbp" method="POST" class="space-y-6">

        <!-- Honeypot: bots fill it, humans don't see it. Formspree drops the submission. -->
        <div style="position:absolute;left:-9999px" aria-hidden="true">
          <label>Leave this empty<input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
        </div>

        <div>
          <label for="name" class="block text-navy font-semibold mb-1">
            Your name <span class="text-amber">*</span>
          </label>
          <input
            type="text"
            name="name"
            id="name"
            required
            autocomplete="name"
            class="w-full rounded-xl border-2 border-slate/20 focus:border-teal focus:outline-none p-3 text-navy"
          />
        </div>

        <div>
          <label for="email" class="block text-navy font-semibold mb-1">
            Work email <span class="text-amber">*</span>
          </label>
          <input
            type="email"
            name="email"
            id="email"
            required
            autocomplete="email"
            class="w-full rounded-xl border-2 border-slate/20 focus:border-teal focus:outline-none p-3 text-navy"
          />
        </div>

        <div>
          <label for="message" class="block text-navy font-semibold mb-1">
            What's on your mind? <span class="text-amber">*</span>
          </label>
          <textarea
            name="message"
            id="message"
            rows="5"
            required
            placeholder="A few lines about what you're working on. We'll take it from there."
            class="w-full rounded-xl border-2 border-slate/20 focus:border-teal focus:outline-none p-3 text-navy"
          ></textarea>
        </div>

        <!-- Optional: only shown if they want a call -->
        <div class="bg-white/60 rounded-xl p-4 border border-slate/10">
          <label class="flex items-center gap-3 text-navy text-sm font-medium cursor-pointer">
            <input type="checkbox" id="prefer-call" class="w-4 h-4" />
            I'd prefer a phone call — let me leave a number.
          </label>
          <div id="phone-wrap" class="hidden mt-3">
            <input
              type="tel"
              name="phone"
              id="phone"
              autocomplete="tel"
              placeholder="+353…"
              class="w-full rounded-xl border-2 border-slate/20 focus:border-teal focus:outline-none p-3 text-navy"
            />
          </div>
        </div>

        <!-- Hidden field, prefilled by URL ?subject= for tier links -->
        <input type="hidden" name="subject" id="subject" value="General enquiry" />

        <div class="text-center">
          <button
            type="submit"
            class="bg-amber text-navy font-bold py-3 px-8 rounded-xl hover:bg-amber/90 transition"
          >
            Start the conversation
          </button>
          <p class="text-slate/60 text-xs mt-3">
            One human reply, usually within 24 hours. No sales sequence.
            <a href="/privacy" class="underline hover:text-slate transition-colors">Privacy policy</a>.
          </p>
        </div>
      </form>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  // URL subject prefill (kept from existing code)
  const params = new URLSearchParams(window.location.search);
  const subject = params.get('subject');
  if (subject) {
    const el = document.getElementById('subject');
    if (el) el.value = subject;
  }

  // Reveal phone field only when the checkbox is ticked
  const pref = document.getElementById('prefer-call');
  const wrap = document.getElementById('phone-wrap');
  pref?.addEventListener('change', () => {
    wrap?.classList.toggle('hidden', !pref.checked);
    if (pref.checked) document.getElementById('phone')?.focus();
  });
</script>
