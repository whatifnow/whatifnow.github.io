/* ========================================================= *
 *  RENDER DASHBOARD GRID
 * ========================================================= */
const grid = document.getElementById('scoreGrid');
AGENTS.forEach(a=>{
  const barClass = a.score>=70?"green":a.score>=60?"amber":"red";
  const el = document.createElement('div');
  el.className = 'score-card';
  el.innerHTML = `
    <div class="score-head">
      <span class="score-agent">${a.initials} · ${a.name.split('·')[0].trim()}</span>
      <span class="pill ${a.score<60?'red':a.score<70?'amber':''}">${a.grade}</span>
    </div>
    <div class="score-lens">${a.name.split('·')[1]?.trim()||a.name}</div>
    <div class="score-big">${a.score}<span>/100</span></div>
    <div class="bar"><i class="${barClass}" style="width:${a.score}%"></i></div>
    <div class="score-note">${a.findings.filter(f=>f.sev==='p0').length} P0 · ${a.findings.filter(f=>f.sev==='p1').length} P1 · ${a.findings.filter(f=>f.sev==='p2').length} P2</div>
  `;
  el.addEventListener('click', ()=>{ switchView('agents'); setTimeout(()=>{
    const t = document.getElementById('agent-'+a.id);
    if(t) t.scrollIntoView({behavior:'smooth', block:'start'});
  }, 100); });
  grid.appendChild(el);
});

/* ========================================================= *
 *  RENDER AGENT CARDS
 * ========================================================= */
const agentContainer = document.getElementById('agentContainer');
AGENTS.forEach((a, i)=>{
  const gradeBg = a.score>=70?'background:#DDF0E6;color:#0d4a2b':a.score>=60?'background:#FAEFD2;color:#6b4c05':'background:#F8E4E4;color:#6b1a1a';
  const wrap = document.createElement('div');
  wrap.id = 'agent-'+a.id;
  wrap.innerHTML = `
    <div class="agent-hero">
      <div class="avatar v${a.v}">${a.initials}</div>
      <div class="name-block">
        <h2>${a.name}</h2>
        <div class="role">${a.role}</div>
        <div class="quote">${a.quote}</div>
      </div>
      <div class="agent-score">
        <div class="n">${a.score}</div>
        <div class="d">of 100</div>
        <div class="g" style="${gradeBg}">Grade · ${a.grade}</div>
      </div>
    </div>
    <div class="findings" id="findings-${a.id}"></div>
    ${i<AGENTS.length-1 ? `<div class="nav-prevnext">
      <a href="#agent-${a.id}">↑ Top of ${a.name.split('·')[0].trim()}</a>
      <a href="#agent-${AGENTS[i+1].id}">Next reviewer · ${AGENTS[i+1].name.split('·')[0].trim()} →</a>
    </div>` : `<div class="nav-prevnext">
      <a href="#agent-${AGENTS[0].id}">↑ Back to first reviewer</a>
      <a href="javascript:void(0)" onclick="switchView('dash')">Back to dashboard →</a>
    </div>`}
  `;
  agentContainer.appendChild(wrap);
  const fwrap = wrap.querySelector('#findings-'+a.id);
  a.findings.forEach(f=>{
    const fel = document.createElement('div');
    fel.className = 'finding' + (f.body.length>260?' full':'');
    fel.innerHTML = `
      <div class="fi-head">
        <span class="sev ${f.sev}">${f.sev.toUpperCase()} · ${f.sev==='p0'?'fix now':f.sev==='p1'?'fix soon':'worth doing'}</span>
        <span class="fi-id">${f.id}</span>
      </div>
      <h4>${f.t}</h4>
      <p>${f.body}</p>
      ${f.quote ? `<div class="quote-block">${f.quote}</div>` : ''}
      <div class="fi-fix">
        <div class="fix-label">The fix</div>
        <p>${f.fix}</p>
      </div>
    `;
    fwrap.appendChild(fel);
  });
});

/* ========================================================= *
 *  TAB SWITCHING
 * ========================================================= */
function switchView(v){
  document.querySelectorAll('.view').forEach(x=>x.classList.remove('active'));
  document.getElementById('view-'+v).classList.add('active');
  document.querySelectorAll('#tabs button').forEach(b=>{
    b.classList.toggle('active', b.dataset.view===v);
  });
  window.scrollTo({top:0, behavior:'smooth'});
  try{ localStorage.setItem('win-audit-view', v); }catch(e){}
}
document.querySelectorAll('#tabs button').forEach(b=>{
  b.addEventListener('click', ()=> switchView(b.dataset.view));
});
// restore last viewed tab
try{
  const v = localStorage.getItem('win-audit-view');
  if(v && ['dash','agents','annot','redesign','deck'].includes(v)) switchView(v);
}catch(e){}

/* ========================================================= *
 *  DECK
 * ========================================================= */
const slides = document.querySelectorAll('#deck .slide');
let sIdx = 0;
function gotoSlide(n){
  sIdx = Math.max(0, Math.min(slides.length-1, n));
  slides.forEach((s,i)=>s.classList.toggle('active', i===sIdx));
  document.getElementById('deckPos').textContent = String(sIdx+1).padStart(2,'0')+' / '+String(slides.length).padStart(2,'0');
  try{ localStorage.setItem('win-audit-deck', String(sIdx)); }catch(e){}
}
document.getElementById('deckPrev').addEventListener('click', ()=>gotoSlide(sIdx-1));
document.getElementById('deckNext').addEventListener('click', ()=>gotoSlide(sIdx+1));
document.addEventListener('keydown', e=>{
  const deckActive = document.getElementById('view-deck').classList.contains('active');
  if(!deckActive) return;
  if(e.key==='ArrowLeft') gotoSlide(sIdx-1);
  if(e.key==='ArrowRight') gotoSlide(sIdx+1);
});
try{
  const n = parseInt(localStorage.getItem('win-audit-deck')||'0',10);
  if(!isNaN(n)) gotoSlide(n);
}catch(e){ gotoSlide(0); }
</script>

