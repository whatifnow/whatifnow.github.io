---
// Renamed to /stare-demo on 2026-05-21. This stub preserves any external
// bookmarks pointing at the old URL — meta refresh + canonical to the new
// path. Set noindex so the rename is clean from a search-engine POV.
const newURL = "https://www.whatifnow.ie/stare-demo/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Moved → Stare Demo | What If Now</title>
    <link rel="canonical" href={newURL} />
    <meta http-equiv="refresh" content={`0; url=${newURL}`} />
    <style>
      body { margin: 0; padding: 40px 24px; background: #FAFAF8; font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif; color: #2D3142; text-align: center; }
      a { color: #1A7D73; font-weight: 600; }
    </style>
  </head>
  <body>
    <p>This page moved. If you aren't redirected, <a href={newURL}>go to the Stare demo</a>.</p>
  </body>
</html>
