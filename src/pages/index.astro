---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import FeaturePills from '../components/FeaturePills.astro';
import PainPoints from '../components/PainPoints.astro';
import EngagementModels from '../components/EngagementModels.astro';
import Compliance from '../components/Compliance.astro';
import About from '../components/About.astro';
import ProductProof from '../components/ProductProof.astro';

import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="What If Now — AI consultancy, Dublin"
  description="What If Now is a Dublin AI consultancy helping teams find where AI actually fits — practical strategy, training, and implementation."
>
  <Navigation />
  <main id="main-content">
    <Hero />
    <PainPoints />
    <FeaturePills />
    <About />
    <ProductProof />
    <Compliance />
    <EngagementModels />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<style is:global>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  section {
    animation: fadeInUp 0.6s ease-out;
  }
</style>
