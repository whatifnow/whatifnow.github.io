---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import PainPoints from '../components/PainPoints.astro';
import ServiceStages from '../components/ServiceStages.astro';
import EngagementModels from '../components/EngagementModels.astro';
import ForensicAudit from '../components/ForensicAudit.astro';
import Compliance from '../components/Compliance.astro';
import HowItWorks from '../components/HowItWorks.astro';
import About from '../components/About.astro';

import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="What If Now | Your team gets their week back">
  <Navigation />
  <main>
    <Hero />
    <PainPoints />
    <ServiceStages />
    <EngagementModels />
    <ForensicAudit />
    <Compliance />
    <HowItWorks />
    <About />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<style is:global>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  section {
    animation: fadeInUp 0.6s ease-out;
  }
</style>
