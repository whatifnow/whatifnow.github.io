---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import FinalCTA from '../components/FinalCTA.astro';
---

<Layout
  title="Solutions | What If Now"
  description="What If Now builds two products: righttostay, a free tenant rights tool in 14 languages, and Stare, precedent intelligence for Irish law firms."
>
  <Navigation />

  <!-- Thank-you banner: shown only when /solutions/?thanks=1 -->
  <div
    id="thanks-banner"
    class="hidden fixed top-16 left-0 right-0 z-40 bg-off-white border-b border-slate/10 shadow-sm"
    role="status"
    aria-live="polite"
  >
    <div class="max-w-4xl mx-auto px-6 py-4 flex items-center gap-4">
      <svg
        class="w-6 h-6 flex-shrink-0 text-teal-dark"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2.5"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
      <div class="flex-grow">
        <p class="text-navy font-semibold">Your message is with us.</p>
        <p class="text-slate text-sm">We reply personally, usually within 24 hours. No sales sequence.</p>
      </div>
      <button
        id="thanks-dismiss"
        type="button"
        class="text-slate hover:text-navy transition-colors p-2 -m-2"
        aria-label="Dismiss confirmation"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <main class="bg-off-white pt-32 pb-24 px-6">

    <!-- Hero -->
    <section class="max-w-3xl mx-auto text-center mb-16">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-navy mb-6 font-serif">
        Two products. One bet.
      </h1>
      <p class="text-slate text-lg md:text-xl leading-relaxed">
        We don't just talk about it. We build the tools — for tenants who need to know their rights, and for the lawyers who help them.
      </p>
    </section>

    <!-- Product cards -->
    <section class="max-w-6xl mx-auto grid md:grid-cols-2 gap-8">

      <!-- righttostay -->
      <article class="bg-white rounded-2xl border border-slate/10 border-t-4 border-t-[#e8554a] p-8 flex flex-col">
        <div class="flex items-center justify-between mb-6">
          <span class="text-xs font-ui font-bold uppercase tracking-wider text-slate">For tenants</span>
          <span class="text-xs font-ui font-bold uppercase tracking-wider px-3 py-1 rounded-full bg-[#e8554a]/10 text-[#e8554a]">Live</span>
        </div>
        <h2 class="text-3xl font-bold text-navy mb-2 font-serif">righttostay</h2>
        <p class="text-lg text-slate italic mb-5">Know your rights. Use them.</p>
        <p class="text-slate leading-relaxed mb-6">
          A free, plain-language tool for anyone renting in Ireland. Ask a question, get an answer grounded in real Residential Tenancies Board decisions. Available in 14 languages so it actually reaches the people who need it.
        </p>
        <ul class="flex flex-wrap gap-x-3 gap-y-2 text-sm text-slate font-medium mb-8 list-none">
          <li>Free</li>
          <li class="text-slate/40" aria-hidden="true">·</li>
          <li>14 languages</li>
          <li class="text-slate/40" aria-hidden="true">·</li>
          <li>RTB-backed</li>
        </ul>
        <div class="mt-auto">
          <a
            href="https://www.righttostay.ie"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#e8554a] hover:bg-[#d44a40] text-white font-ui font-bold px-6 py-3 rounded-full transition-colors"
          >
            Visit righttostay.ie
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </article>

      <!-- Stare -->
      <article class="bg-white rounded-2xl border border-slate/10 border-t-4 border-t-teal p-8 flex flex-col">
        <div class="flex items-center justify-between mb-6">
          <span class="text-xs font-ui font-bold uppercase tracking-wider text-slate">For lawyers + compliance teams</span>
          <span class="text-xs font-ui font-bold uppercase tracking-wider px-3 py-1 rounded-full bg-teal/10 text-teal-dark">Early access</span>
        </div>
        <h2 class="text-3xl font-bold text-navy mb-2 font-serif">Stare</h2>
        <p class="text-lg text-slate italic mb-5">Precedent intelligence for Irish law.</p>
        <p class="text-slate leading-relaxed mb-6">
          A searchable corpus of 25,000+ Residential Tenancies Board decisions, embedded and queryable in seconds. Built for law firms doing housing work and for compliance teams who need to see how the Tribunal has actually decided cases. MCP-ready, so it plugs into the AI tools your team already uses.
        </p>
        <ul class="flex flex-wrap gap-x-3 gap-y-2 text-sm text-slate font-medium mb-8 list-none">
          <li>25,000+ decisions</li>
          <li class="text-slate/40" aria-hidden="true">·</li>
          <li>Vector search</li>
          <li class="text-slate/40" aria-hidden="true">·</li>
          <li>MCP-ready</li>
        </ul>
        <div class="mt-auto flex flex-wrap gap-3">
          <a
            href="/precedent-demo"
            class="inline-flex items-center gap-2 bg-amber hover:bg-amber-dark text-charcoal font-ui font-bold px-6 py-3 rounded-full transition-colors"
          >
            Try the Precedent Explorer
            <span aria-hidden="true">→</span>
          </a>
          <a
            href="/contact?subject=Stare+-+Tell+me+more"
            class="inline-flex items-center gap-2 bg-navy hover:bg-navy-light text-white font-ui font-bold px-6 py-3 rounded-full transition-colors"
          >
            Talk to us about Stare
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </article>

    </section>

    <!-- Bridge -->
    <section class="max-w-3xl mx-auto text-center mt-20">
      <p class="text-slate text-lg italic">
        We build because we use it ourselves. The consulting work and the products feed each other.
      </p>
    </section>

  </main>

  <FinalCTA />
  <Footer />
</Layout>

<script>
  const banner = document.getElementById('thanks-banner');
  const dismiss = document.getElementById('thanks-dismiss');
  const params = new URLSearchParams(window.location.search);

  function hideBanner() {
    banner?.classList.add('hidden');
  }

  if (banner && params.get('thanks') === '1') {
    banner.classList.remove('hidden');
    // Clean the URL so refresh / share doesn't re-show the banner
    history.replaceState(null, '', '/solutions/');
    // Auto-dismiss after 8 seconds
    setTimeout(hideBanner, 8000);
  }

  dismiss?.addEventListener('click', hideBanner);
</script>
